# ---------------------------------------------------------------------------
# Google Maps JavaScript API key (REQUIRED for the route map to render).
# Browser-restricted key — referrer allowlist must include http://localhost:*
# and your deployed origin.
# ---------------------------------------------------------------------------
VITE_GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Backend base URL. Optional — the app already falls back per build mode:
#   dev build  → http://localhost:5050
#   prod build → https://supplychainfaraway.duckdns.org
# Set this only if you want to point local dev at a different backend
# (e.g. the deployed VM while iterating on the UI without running the
# backend locally).
# ---------------------------------------------------------------------------
# VITE_API_URL=https://supplychainfaraway.duckdns.org

# ---------------------------------------------------------------------------
# Override just for the legacy REST `/api/analyze-product` upload endpoint
# (Compliance → Product Analysis). Falls back to VITE_API_URL when unset.
# ---------------------------------------------------------------------------
# VITE_BACKEND_URL=https://supplychainfaraway.duckdns.org
