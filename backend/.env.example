# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT
JWT_SECRET=<your-strong-random-secret>

# Vertex AI (Gemini via Google Cloud)
GOOGLE_CLOUD_PROJECT=<gcp-project-id>
VERTEX_AI_LOCATION=us-central1
# Local dev: path (relative to backend/) of the service-account JSON key with roles/aiplatform.user
GOOGLE_APPLICATION_CREDENTIALS=./Config/vertex-ai-key.json
# Prod (Duck DNS host): paste the full JSON string of the SA key instead of using a file path.
# When both are set, GOOGLE_APPLICATION_CREDENTIALS_JSON wins.
GOOGLE_APPLICATION_CREDENTIALS_JSON=<json-string-of-vertex-ai-sa-key>

# Google Cloud Storage + Vision
GOOGLE_CLOUD_BUCKET_NAME=<your-gcs-bucket-name>
# In production, set this to the JSON string of your service-account credentials key file
GOOGLE_CLOUD_CREDENTIALS_JSON=<json-string-of-service-account-credentials>

# Google Maps Platform (Geocoding API, Routes API, Maps JavaScript API)
# Server-restricted key — used by the backend to geocode route waypoints and
# fetch encoded polylines. Enable the three APIs above on the GCP project.
GOOGLE_API_KEY=<your-google-maps-server-key>

# Carbon Interface API
CARBON_INTERFACE_API_KEY=<your-carbon-interface-api-key>

# News API (https://newsapi.org)
NEWS_API_KEY=<your-newsapi-org-api-key>

# Server — frontend defaults to localhost:5050 in dev, change in lockstep if you move this
PORT=5050
NODE_ENV=development

# URLs
FRONTEND_URL=https://<your-frontend-domain>
BACKEND_URL=https://<your-backend-domain>
